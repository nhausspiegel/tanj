{
  "name": "news_agg",
  "version": "0.1.0",
  "description": "Local-first tech intelligence command center.",
  "main": "electron/main.js",
  "author": "Montster27",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "preinstall": "node scripts/check-node-arch.cjs",
    "dev": "next dev --experimental-https",
    "dev:web": "next dev --port 3000",
    "dev:web:desktop": "ELECTRON_RENDERER_MODE=desktop next dev --port 3000",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "electron:wait": "npm run rebuild:electron && ELECTRON_RENDERER_URL=http://127.0.0.1:3000 electron .",
    "dev:desktop": "node scripts/dev-desktop.cjs",
    "build": "next build",
    "start": "next start",
    "package:desktop": "npm run rebuild:electron && electron-forge package",
    "make:desktop": "npm run rebuild:electron && electron-forge make",
    "lint": "eslint .",
    "test": "npm run rebuild:node && vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rss-parser": "^3.13.0"
  },
  "config": {
    "forge": "./forge.config.js"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/parser": "^8.30.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "eslint": "^9.25.1",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.5"
  }
}
